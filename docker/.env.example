# Copy this to .env and fill in the values before running docker compose

# PostgreSQL password — change before deploying
POSTGRES_PASSWORD=changeme

# Session secret — generate a random string: openssl rand -hex 32
SESSION_SECRET=change-this-secret

# Port to expose on the host (default: 80)
PORT=80

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info
