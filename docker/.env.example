# Copy this to .env at the repo root and fill in the values before
# running `docker compose up -d --build`.

# ── Database
# Postgres runs inside the linedeck network only — this password is used by
# `app` to connect to the internal `db` container.
POSTGRES_PASSWORD=changeme

# ── App
# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=change-this-secret

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# Host port to expose the LineDeck app on. Nginx Proxy Manager (or whatever
# reverse proxy you run on the host) should forward your domain to this port.
# Default 8090 avoids the common 80 / 5000 collisions.
LINEDECK_HOST_PORT=8090

# ── Guacamole
# Base URL of your Guacamole web app (no trailing slash), e.g.:
#   http://10.63.12.105:8080/guacamole
GUACAMOLE_URL=http://10.63.12.105:8080/guacamole

# Service account used by LineDeck to mint per-session tokens via Guacamole's
# REST API. Grant it READ on every connection that LineDeck should expose.
GUACAMOLE_USERNAME=linedeck
GUACAMOLE_PASSWORD=change-this-password
